---
import '../styles/main.css';
import { translations, type Lang } from '../lib/i18n';
import AboutContent from '../components/AboutContent.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = translations[lang];

const urls: Record<Lang, string> = {
  fr: 'https://meridian-way.ch/',
  de: 'https://meridian-way.ch/de/',
  it: 'https://meridian-way.ch/it/',
  en: 'https://meridian-way.ch/en/',
};
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{t.title}</title>
  <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="shortcut icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#0e120a" />
  <meta name="description" content={t.meta_description} />
  <link rel="canonical" href={urls[lang]} />
  <link rel="alternate" hreflang="fr" href={urls.fr} />
  <link rel="alternate" hreflang="de" href={urls.de} />
  <link rel="alternate" hreflang="it" href={urls.it} />
  <link rel="alternate" hreflang="en" href={urls.en} />
  <link rel="alternate" hreflang="x-default" href={urls.fr} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={urls[lang]} />
  <meta property="og:title" content={t.title} />
  <meta property="og:description" content={t.meta_description} />
  <meta property="og:image" content="https://meridian-way.ch/meridian-way-og.png" />
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "MeridianWay",
    "url": urls[lang],
    "description": t.meta_description,
    "applicationCategory": "TravelApplication",
    "operatingSystem": "Web",
    "inLanguage": ["fr", "de", "it", "en"],
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "CHF" },
    "author": { "@type": "Person", "url": "https://github.com/paultursuru" }
  })} />
</head>
<body>

<div id="app">
  <div id="header">
    <h1><span class="meri">Meridian</span><span class="way">Way</span></h1>
    <div id="header-right">
      <div id="sun-info"></div>
      <button id="about-btn" aria-label={t.aria_about}>i</button>
    </div>
  </div>
  <div id="search-panel">
    <div class="input-wrap">
      <input type="text" id="inp-start" placeholder={t.placeholder_start} />
      <button class="geo-btn" id="geo-start" title={t.geo_btn_title} aria-label={t.geo_btn_title}>📍</button>
    </div>
    <div class="input-wrap">
      <input type="text" id="inp-end" placeholder={t.placeholder_end} />
      <button class="geo-btn" id="geo-end" title={t.geo_btn_title} aria-label={t.geo_btn_title}>📍</button>
    </div>
    <div class="dt-row">
      <input type="date" id="inp-date" />
      <input type="time" id="inp-time" />
      <button id="search-btn">{t.btn_search}</button>
    </div>
  </div>
  <div id="map"></div>
</div>

<div id="status"></div>

<div id="about-overlay"></div>
<div id="about-drawer" role="dialog" aria-modal="true" aria-label={t.aria_about}>
  <div id="about-header">
    <div id="about-lang">
      <button class:list={['lang-btn', { active: lang === 'fr' }]} data-lang="fr">FR</button>
      <button class:list={['lang-btn', { active: lang === 'de' }]} data-lang="de">DE</button>
      <button class:list={['lang-btn', { active: lang === 'it' }]} data-lang="it">IT</button>
      <button class:list={['lang-btn', { active: lang === 'en' }]} data-lang="en">EN</button>
    </div>
    <button id="about-close" aria-label={t.aria_close}>×</button>
  </div>

  <div id="about-body">
    <AboutContent lang={lang} allLangs={true} />
  </div>

  <div id="about-links">
    <a href="https://github.com/paultursuru/meridian" target="_blank" rel="noopener" class="about-link github-link">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.603-3.369-1.342-3.369-1.342-.454-1.155-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.741 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/></svg>
      GitHub
    </a>
    <a href="https://ko-fi.com/meridian_way" target="_blank" rel="noopener" class="about-link kofi-link">
      ☕ Ko-fi
    </a>
  </div>
</div>

<div id="compass-wrap">
  <div id="compass-box">
    <canvas id="compass-cv" width="60" height="60"></canvas>
  </div>
  <div id="compass-label">{t.compass_label}</div>
</div>

<div id="results">
  <div id="drawer-handle" aria-label={t.aria_drawer_toggle} role="button" tabindex="0">
    <div id="drawer-bar"></div>
  </div>
  <div id="tabs">
    <button class="tab-btn shady"  data-tab="shady">{t.tab_shady}</button>
    <button class="tab-btn active" data-tab="sunny">{t.tab_sunny}</button>
  </div>
  <div id="tab-sunny" class="tab-pane active">
    <div class="ratio-wrap">
      <div class="ratio-nums">
        <span class="ratio-shade-num">{t.label_shade} <strong id="sunny-shade-pct"></strong></span>
        <span class="ratio-sun-num"><strong id="sunny-sun-pct"></strong> {t.label_sun}</span>
      </div>
      <div class="ratio-track">
        <div class="ratio-fill" id="sunny-ratio-fill" style="width:0%"></div>
      </div>
    </div>
    <div class="route-details">
      <div class="detail-stats">
        <div class="detail-stat">
          <span class="stat-val" id="sunny-dist"></span>
          <span class="stat-lbl">{t.label_distance}</span>
        </div>
        <div class="detail-stat">
          <span class="stat-val" id="sunny-dur"></span>
          <span class="stat-lbl">{t.label_duration}</span>
        </div>
        <div class="detail-stat" id="sunny-elev-stat" style="display:none">
          <span class="stat-val elev-val" id="sunny-elev"></span>
          <span class="stat-lbl">{t.label_elevation}</span>
        </div>
      </div>
      <div class="detail-split">
        <div class="detail-split-shade">
          <span class="split-val" id="sunny-shaded-dist"></span>
          <span class="split-lbl">{t.label_shade}</span>
        </div>
        <div class="detail-split-sun">
          <span class="split-val" id="sunny-sun-dist"></span>
          <span class="split-lbl">{t.label_sun}</span>
        </div>
      </div>
    </div>
  </div>

  <div id="tab-shady" class="tab-pane">
    <div class="ratio-wrap">
      <div class="ratio-nums">
        <span class="ratio-shade-num">{t.label_shade} <strong id="shady-shade-pct"></strong></span>
        <span class="ratio-sun-num"><strong id="shady-sun-pct"></strong> {t.label_sun}</span>
      </div>
      <div class="ratio-track">
        <div class="ratio-fill" id="shady-ratio-fill" style="width:0%"></div>
      </div>
    </div>
    <div class="route-details">
      <div class="detail-stats">
        <div class="detail-stat">
          <span class="stat-val" id="shady-dist"></span>
          <span class="stat-lbl">{t.label_distance}</span>
        </div>
        <div class="detail-stat">
          <span class="stat-val" id="shady-dur"></span>
          <span class="stat-lbl">{t.label_duration}</span>
        </div>
        <div class="detail-stat" id="shady-elev-stat" style="display:none">
          <span class="stat-val elev-val" id="shady-elev"></span>
          <span class="stat-lbl">{t.label_elevation}</span>
        </div>
      </div>
      <div class="detail-split">
        <div class="detail-split-shade">
          <span class="split-val" id="shady-shaded-dist"></span>
          <span class="split-lbl">{t.label_shade}</span>
        </div>
        <div class="detail-split-sun">
          <span class="split-val" id="shady-sun-dist"></span>
          <span class="split-lbl">{t.label_sun}</span>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  import { initMap, displayRoutes, setActiveRoute, setPreviewPin } from '../lib/map.js';
  import { getSun }                      from '../lib/sun.js';
  import { geocode, reverseGeocode }     from '../lib/geocode.js';
  import { buildRoutes }                 from '../lib/routing.js';
  import { routesBbox, fetchBuildings }  from '../lib/buildings.js';
  import { fetchTrees }                  from '../lib/trees.js';
  import { scoreRoute }                  from '../lib/shadow.js';
  import { deciduousLeafFrac }           from '../lib/season.js';
  import { drawCompass }                 from '../lib/compass.js';
  import { setStatus, initTabs, showResults, setActiveTab, renderTab } from '../lib/ui.js';
  import { initAutocomplete }            from '../lib/autocomplete.js';
  import { tr }                          from '../lib/i18n.js';


  initMap();
  initTabs((type: string) => setActiveRoute(type));

  window.addEventListener('route-select', (e: Event) => {
    const type = (e as CustomEvent<{ type: string }>).detail.type;
    setActiveTab(type);
    setActiveRoute(type);
  });

  const el = <T extends HTMLElement>(id: string) => document.getElementById(id) as T;
  const input  = (id: string) => el<HTMLInputElement>(id);
  const button = (id: string) => el<HTMLButtonElement>(id);

  const now = new Date();
  input('inp-date').value = now.toISOString().split('T')[0];
  input('inp-time').value = now.toTimeString().slice(0, 5);

  let startAC: ReturnType<typeof initAutocomplete>;
  let endAC:   ReturnType<typeof initAutocomplete>;
  startAC = initAutocomplete(input('inp-start'), { onSelect: (p: { lat: number; lng: number }) => setPreviewPin('start', p), getAnchor: () => endAC?.getPlace() });
  endAC   = initAutocomplete(input('inp-end'),   { onSelect: (p: { lat: number; lng: number }) => setPreviewPin('end',   p), getAnchor: () => startAC.getPlace() });

  // Default map center (Lausanne) — used for sun-info at page load
  const MAP_LAT = 46.5197, MAP_LNG = 6.6323;

  function updateSunInfo(sun: { azDeg: number; altDeg: number }) {
    const infoEl = el('sun-info');
    infoEl.classList.toggle('day',   sun.altDeg > 0);
    infoEl.classList.toggle('night', sun.altDeg <= 0);
    infoEl.classList.add('visible');
    if (sun.altDeg <= 0) {
      infoEl.textContent = tr('status_night', { alt: sun.altDeg.toFixed(1) });
    } else {
      infoEl.textContent = tr('status_sun', { alt: sun.altDeg.toFixed(1), az: sun.azDeg.toFixed(0) });
    }
  }

  // Show sun position immediately on load
  updateSunInfo(getSun(now, MAP_LAT, MAP_LNG));

  function logShadowDebug({ startQ, endQ, startC, endC, tDate, sun, bbox, buildings, trees, leafFrac, routes }: {
    startQ: string; endQ: string;
    startC: { lat: number; lng: number }; endC: { lat: number; lng: number };
    tDate: Date; sun: { azDeg: number; altDeg: number };
    bbox: number[]; buildings: unknown[]; trees: unknown[]; leafFrac: number;
    routes: { distance: number; sunScore: number; segShade: { i: number; shade: boolean }[]; geometry: { coordinates: number[][] } }[];
  }) {
    const payload = {
      query: { from: startQ, to: endQ },
      start: startC,
      end: endC,
      datetime: tDate.toISOString(),
      sun: { altDeg: +sun.altDeg.toFixed(2), azDeg: +sun.azDeg.toFixed(1) },
      bbox: bbox.map(v => +v.toFixed(5)),
      buildingCount: buildings.length,
      treeCount: trees.length,
      leafFrac,
      routes: routes.map((rt, idx) => ({
        index: idx,
        distanceM: Math.round(rt.distance),
        sunScore: +rt.sunScore.toFixed(4),
        shadedSegments: rt.segShade.filter(s => s.shade).length,
        totalSegments: rt.segShade.length,
        segShade: rt.segShade,
        coordinates: rt.geometry.coordinates,
      })),
    };
    // keeping this if debug needed
    // console.log('SHADOW_DEBUG_JSON ' + JSON.stringify(payload));
  }

  async function handleSearch() {
    const startQ = input('inp-start').value.trim();
    const endQ   = input('inp-end').value.trim();
    const dateV  = input('inp-date').value;
    const timeV  = input('inp-time').value;

    if (!startQ || !endQ) { alert(tr('alert_empty')); return; }

    const btn = button('search-btn');
    btn.disabled = true;
    el('results').classList.remove('on');
    el('compass-wrap').classList.remove('on');

    try {
      setStatus(tr('status_geocoding'));
      const [startC, endC] = await Promise.all([
        startAC.getPlace() ?? geocode(startQ),
        endAC.getPlace()   ?? geocode(endQ),
      ]);

      let tDate = new Date();
      if (dateV && timeV) tDate = new Date(`${dateV}T${timeV}`);
      else if (dateV)     tDate = new Date(`${dateV}T12:00:00`);

      const midLat = (startC.lat + endC.lat) / 2;
      const midLng = (startC.lng + endC.lng) / 2;
      const sun = getSun(tDate, midLat, midLng);

      updateSunInfo(sun);
      drawCompass(sun.azDeg, sun.altDeg);
      el('compass-wrap').classList.add('on');

      const routes = await buildRoutes(startC, endC, setStatus);
      if (!routes.length) throw new Error(tr('error_no_route'));

      setStatus(tr('status_buildings'));
      const bbox = routesBbox(routes);
      const buildings = await fetchBuildings(bbox);
      const trees = await fetchTrees(bbox);
      const leafFrac = deciduousLeafFrac(tDate);

      setStatus(tr('status_shadows', { n: String(buildings.length), r: String(routes.length) }));
      routes.forEach(rt => {
        const { score, segShade } = scoreRoute(rt, buildings, trees, sun, leafFrac);
        rt.sunScore = score;
        rt.segShade = segShade;
      });
      routes.sort((a, b) => b.sunScore - a.sunScore);

      const sunny = routes[0];
      const shady = routes[routes.length - 1];

      displayRoutes(startC, endC, sunny, shady);
      showResults(sunny, shady);

      const preselect = sun.altDeg > 40 ? 'shady' : 'sunny';
      setActiveTab(preselect);
      setActiveRoute(preselect);

      renderTab('tab-sunny', sunny);
      renderTab('tab-shady', shady);
      setStatus(null);

      logShadowDebug({ startQ, endQ, startC, endC, tDate, sun, bbox, buildings, trees, leafFrac, routes });

    } catch (err) {
      setStatus(null);
      alert(tr('error_prefix') + (err instanceof Error ? err.message : String(err)));
      console.error(err);
    } finally {
      button('search-btn').disabled = false;
    }
  }

  async function fillFromGeo(ac: ReturnType<typeof initAutocomplete>, role: 'start' | 'end', btnId: string) {
    const btn = button(btnId);
    btn.disabled = true;
    btn.classList.add('loading');
    setStatus(tr('geo_loading'));
    try {
      const pos = await new Promise<GeolocationPosition>((resolve, reject) => {
        navigator.geolocation.getCurrentPosition(resolve, reject, { timeout: 10000 });
      });
      const label = await reverseGeocode(pos.coords.latitude, pos.coords.longitude);
      const lat = pos.coords.latitude, lng = pos.coords.longitude;
      ac.setPlace({ lat, lng, label });
      setPreviewPin(role, { lat, lng });
      setStatus(null);
    } catch (err: unknown) {
      setStatus(null);
      if ((err as GeolocationPositionError)?.code === 1) {
        alert(tr('error_geo_denied'));
      } else {
        alert(tr('error_geo_timeout'));
      }
    } finally {
      btn.disabled = false;
      btn.classList.remove('loading');
    }
  }

  button('geo-start').addEventListener('click', () => fillFromGeo(startAC, 'start', 'geo-start'));
  button('geo-end').addEventListener('click',   () => fillFromGeo(endAC,   'end',   'geo-end'));

  button('search-btn').addEventListener('click', handleSearch);
  ['inp-start', 'inp-end'].forEach(id =>
    input(id).addEventListener('keydown', (e: KeyboardEvent) => { if (e.key === 'Enter') handleSearch(); })
  );

  const drawer  = el('about-drawer');
  const overlay = el('about-overlay');

  function openAbout() {
    drawer.classList.add('open');
    overlay.classList.add('on');
  }
  function closeAbout() {
    drawer.classList.remove('open');
    overlay.classList.remove('on');
  }

  el('about-btn').addEventListener('click', openAbout);
  el('about-close').addEventListener('click', closeAbout);
  overlay.addEventListener('click', closeAbout);
  document.addEventListener('keydown', (e: KeyboardEvent) => { if (e.key === 'Escape') closeAbout(); });

  document.querySelectorAll('.lang-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const lang = (btn as HTMLElement).dataset.lang!;
      document.querySelectorAll('.lang-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      document.querySelectorAll('.about-pane').forEach(p => {
        p.classList.toggle('active', (p as HTMLElement).dataset.lang === lang);
      });
    });
  });
</script>

</body>
</html>
