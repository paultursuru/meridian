---
import '../styles/main.css';
import { translations, type Lang } from '../lib/i18n';
import AboutContent from '../components/AboutContent.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = translations[lang];

const urls: Record<Lang, string> = {
  fr: 'https://meridian-way.ch/',
  de: 'https://meridian-way.ch/de/',
  it: 'https://meridian-way.ch/it/',
  en: 'https://meridian-way.ch/en/',
};
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{t.title}</title>
  <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="shortcut icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#0e120a" />
  <meta name="description" content={t.meta_description} />
  <link rel="canonical" href={urls[lang]} />
  <link rel="alternate" hreflang="fr" href={urls.fr} />
  <link rel="alternate" hreflang="de" href={urls.de} />
  <link rel="alternate" hreflang="it" href={urls.it} />
  <link rel="alternate" hreflang="en" href={urls.en} />
  <link rel="alternate" hreflang="x-default" href={urls.fr} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={urls[lang]} />
  <meta property="og:title" content={t.title} />
  <meta property="og:description" content={t.meta_description} />
  <meta property="og:image" content="https://meridian-way.ch/meridian-way-og.png" />
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "MeridianWay",
    "url": urls[lang],
    "description": t.meta_description,
    "applicationCategory": "TravelApplication",
    "operatingSystem": "Web",
    "inLanguage": ["fr", "de", "it", "en"],
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "CHF" },
    "author": { "@type": "Person", "url": "https://github.com/paultursuru" }
  })} />
  <script defer src="https://cloud.umami.is/script.js" data-website-id="3ed0ad98-8924-4e14-aa5b-6afe5d3dc7ac"></script>
</head>
<body>

<div id="app">
  <div id="header">
    <h1>
      <a href="/">
        <span class="meri">Meridian</span><span class="way">Way</span>
      </a>
    </h1>
    <div id="header-right">
      <div id="sun-info">
        <div class="sun-info-track">
          <span class="sun-info-line">{t.navbar_tagline}</span>
          <span class="sun-info-line"></span>
          <span class="sun-info-line"></span>
        </div>
      </div>
      <button id="about-btn" aria-label={t.aria_about}>i</button>
    </div>
  </div>
  <div id="install-banner">
    <span id="install-banner-text"></span>
    <div id="install-banner-actions">
      <button id="install-banner-btn">{t.install_banner_btn}</button>
      <button id="install-banner-close" aria-label={t.aria_close}>×</button>
    </div>
  </div>
  <div id="search-panel">
    <div class="route-inputs">
      <div class="input-wrap">
        <input type="text" id="inp-start" placeholder={t.placeholder_start} />
        <button class="geo-btn" id="geo-start" title={t.geo_btn_title} aria-label={t.geo_btn_title}>📍</button>
      </div>
      <button id="swap-btn" type="button" title={t.swap_btn_title} aria-label={t.swap_btn_title}><span class="swap-ico">⇅</span></button>
      <div class="input-wrap">
        <input type="text" id="inp-end" placeholder={t.placeholder_end} />
        <button class="geo-btn" id="geo-end" title={t.geo_btn_title} aria-label={t.geo_btn_title}>📍</button>
      </div>
    </div>
    <div class="dt-row">
      <input type="date" id="inp-date" />
      <input type="time" id="inp-time" />
      <button id="search-btn">{t.btn_search}</button>
    </div>
  </div>
  <div id="map">
    <div id="map-splash"><span>{t.map_loading}</span></div>
  </div>
</div>

<div id="status"></div>

<div id="about-overlay"></div>
<div id="about-drawer" role="dialog" aria-modal="true" aria-label={t.aria_about}>
  <div id="about-header">
    <div id="about-lang">
      <a class:list={['lang-btn', { active: lang === 'fr' }]} href="/">FR</a>
      <a class:list={['lang-btn', { active: lang === 'de' }]} href="/de/">DE</a>
      <a class:list={['lang-btn', { active: lang === 'it' }]} href="/it/">IT</a>
      <a class:list={['lang-btn', { active: lang === 'en' }]} href="/en/">EN</a>
    </div>
    <button id="about-close" aria-label={t.aria_close}>×</button>
  </div>

  <div id="about-body">
    <AboutContent lang={lang} />
  </div>

  <div id="about-links">
    <a href="https://github.com/paultursuru/meridian" target="_blank" rel="noopener" class="about-link github-link">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.603-3.369-1.342-3.369-1.342-.454-1.155-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.741 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/></svg>
      GitHub
    </a>
    <a href="https://ko-fi.com/meridian_way" target="_blank" rel="noopener" class="about-link kofi-link">
      ☕ Ko-fi
    </a>
  </div>
  <div class="footer-links">
    <a href={lang === 'fr' ? '/about' : `/${lang}/about`} class="footer-link">{t.aria_about}</a>
    <span class="footer-link">-</span>
    <a href={lang === 'fr' ? '/privacy' : `/${lang}/privacy`} class="footer-link">{t.about_privacy}</a>
  </div>
</div>

<div id="compass-wrap">
  <div id="compass-box">
    <canvas id="compass-cv" width="60" height="60"></canvas>
  </div>
  <div id="compass-label">{t.compass_label}</div>
</div>

<div id="results">
  <div id="drawer-handle" aria-label={t.aria_drawer_toggle} role="button" tabindex="0">
    <div id="drawer-bar"></div>
  </div>
  <button id="share-btn" title={t.share_btn_title} aria-label={t.share_btn_title}>
    <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92s2.92-1.31 2.92-2.92-1.31-2.92-2.92-2.92z"/></svg>
  </button>
  <div id="weather-note"></div>
  <div id="night-note">{t.night_note}</div>
  <div id="single-route-note">{t.single_route_note}</div>
  <div id="tabs">
    <button class="tab-btn shady"  data-tab="shady">{t.tab_shady}</button>
    <button class="tab-btn active" data-tab="sunny">{t.tab_sunny}</button>
  </div>
  <div id="tab-sunny" class="tab-pane active">
    <div class="ratio-wrap">
      <div class="ratio-nums">
        <span class="ratio-shade-num">{t.label_shade} <strong id="sunny-shade-pct"></strong></span>
        <span class="ratio-sun-num"><strong id="sunny-sun-pct"></strong> {t.label_sun}</span>
      </div>
      <div class="ratio-track">
        <div class="ratio-fill" id="sunny-ratio-fill" style="width:0%"></div>
      </div>
    </div>
    <div class="route-details">
      <div class="detail-stats">
        <div class="detail-stat">
          <span class="stat-val" id="sunny-dist"></span>
          <span class="stat-lbl">{t.label_distance}</span>
        </div>
        <div class="detail-stat">
          <span class="stat-val" id="sunny-dur"></span>
          <span class="stat-lbl">{t.label_duration}</span>
        </div>
        <div class="detail-stat" id="sunny-elev-stat" style="display:none">
          <span class="stat-val elev-val" id="sunny-elev"></span>
          <span class="stat-lbl">{t.label_elevation}</span>
        </div>
      </div>
      <div class="detail-split">
        <div class="detail-split-shade">
          <span class="split-val" id="sunny-shaded-dist"></span>
          <span class="split-lbl">{t.label_shade}</span>
        </div>
        <div class="detail-split-sun">
          <span class="split-val" id="sunny-sun-dist"></span>
          <span class="split-lbl">{t.label_sun}</span>
        </div>
      </div>
    </div>
  </div>

  <div id="tab-shady" class="tab-pane">
    <div class="ratio-wrap">
      <div class="ratio-nums">
        <span class="ratio-shade-num">{t.label_shade} <strong id="shady-shade-pct"></strong></span>
        <span class="ratio-sun-num"><strong id="shady-sun-pct"></strong> {t.label_sun}</span>
      </div>
      <div class="ratio-track">
        <div class="ratio-fill" id="shady-ratio-fill" style="width:0%"></div>
      </div>
    </div>
    <div class="route-details">
      <div class="detail-stats">
        <div class="detail-stat">
          <span class="stat-val" id="shady-dist"></span>
          <span class="stat-lbl">{t.label_distance}</span>
        </div>
        <div class="detail-stat">
          <span class="stat-val" id="shady-dur"></span>
          <span class="stat-lbl">{t.label_duration}</span>
        </div>
        <div class="detail-stat" id="shady-elev-stat" style="display:none">
          <span class="stat-val elev-val" id="shady-elev"></span>
          <span class="stat-lbl">{t.label_elevation}</span>
        </div>
      </div>
      <div class="detail-split">
        <div class="detail-split-shade">
          <span class="split-val" id="shady-shaded-dist"></span>
          <span class="split-lbl">{t.label_shade}</span>
        </div>
        <div class="detail-split-sun">
          <span class="split-val" id="shady-sun-dist"></span>
          <span class="split-lbl">{t.label_sun}</span>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  import { initMap, displayRoutes, setActiveRoute, setPreviewPin, swapPreviewPins } from '../lib/map.js';
  import { getSun, getSunTimes, compassDir, makeSunSampler } from '../lib/sun.js';
  import { geocode, reverseGeocode }     from '../lib/geocode.js';
  import { buildRoutes }                 from '../lib/routing.js';
  import { routesBbox, fetchBuildings }  from '../lib/buildings.js';
  import { fetchVegetation }             from '../lib/trees.js';
  import { scoreRoute }                  from '../lib/shadow.js';
  import { deciduousLeafFrac }           from '../lib/season.js';
  import { resolveTimeZone, zonedTimeToUtc, formatTimeInZone } from '../lib/timezone.js';
  import { fetchWeather }                from '../lib/weather.js';
  import { preselectTab }                from '../lib/preselect.js';
  import { drawCompass }                 from '../lib/compass.js';
  import { setStatus, showToast, initTabs, showResults, setActiveTab } from '../lib/ui.js';
  import { initAutocomplete }            from '../lib/autocomplete.js';
  import { buildShareQuery, parseShareQuery } from '../lib/share.js';
  import { tr, type TranslationKey }     from '../lib/i18n.js';
  import { localDateValue }              from '../lib/helpers.js';
  import { initInstallPrompt }           from '../lib/pwa.js';


  initMap();
  initTabs((type: string) => setActiveRoute(type));
  initInstallPrompt();

  window.addEventListener('route-select', (e: Event) => {
    const type = (e as CustomEvent<{ type: string }>).detail.type;
    setActiveTab(type);
    setActiveRoute(type);
  });

  const el = <T extends HTMLElement>(id: string) => document.getElementById(id) as T;
  const input  = (id: string) => el<HTMLInputElement>(id);
  const button = (id: string) => el<HTMLButtonElement>(id);

  const now = new Date();
  input('inp-date').value = localDateValue(now);
  input('inp-time').value = now.toTimeString().slice(0, 5);

  let startAC: ReturnType<typeof initAutocomplete>;
  let endAC:   ReturnType<typeof initAutocomplete>;
  startAC = initAutocomplete(input('inp-start'), { onSelect: (p: { lat: number; lng: number }) => setPreviewPin('start', p), getAnchor: () => endAC?.getPlace() });
  endAC   = initAutocomplete(input('inp-end'),   { onSelect: (p: { lat: number; lng: number }) => setPreviewPin('end',   p), getAnchor: () => startAC.getPlace() });

  // Cloud cover (%) above which the sunny/shady distinction stops mattering
  const OVERCAST_PCT = 60;

  // Header's sun-info slot: the tagline (rendered server-side, see the
  // markup above) alone until the first search; from then on a 3-beat
  // loop — tagline, plain-language sun position, exact degrees (review
  // 3.3 — nobody knows what azimuth is, but this app is as much about
  // exploring the sky as it is about routing, so keep both). The timing
  // and slide are a pure-CSS animation (`.cycling`, see main.css); this
  // only fills the text and switches the animation on.
  function updateSunInfo(sun: { azDeg: number; altDeg: number }, times: { sunrise: Date; sunset: Date }, timeZone: string) {
    const infoEl = el('sun-info');
    infoEl.classList.toggle('day',   sun.altDeg > 0);
    infoEl.classList.toggle('night', sun.altDeg <= 0);

    const human = sun.altDeg <= 0
      ? tr('night_position', { time: formatTimeInZone(times.sunrise, timeZone) })
      : tr('sun_position', { dir: tr(('dir_' + compassDir(sun.azDeg)) as TranslationKey), time: formatTimeInZone(times.sunset, timeZone) });
    const technical = tr('status_sun', { alt: sun.altDeg.toFixed(1), az: sun.azDeg.toFixed(0) });
    const lines = infoEl.querySelectorAll<HTMLSpanElement>('.sun-info-line');
    lines[1].textContent = human;
    lines[2].textContent = technical;
    infoEl.classList.add('cycling');
  }


  function logShadowDebug({ startQ, endQ, startC, endC, tDate, sun, bbox, buildings, trees, leafFrac, routes }: {
    startQ: string; endQ: string;
    startC: { lat: number; lng: number }; endC: { lat: number; lng: number };
    tDate: Date; sun: { azDeg: number; altDeg: number };
    bbox: number[]; buildings: unknown[]; trees: unknown[]; leafFrac: number;
    routes: { distance: number; sunScore: number; segShade: { i: number; shade: boolean }[]; geometry: { coordinates: number[][] } }[];
  }) {
    // console.log('SHADOW_DEBUG_JSON ' + JSON.stringify({ query: { from: startQ, to: endQ }, start: startC, end: endC, datetime: tDate.toISOString(), sun: { altDeg: +sun.altDeg.toFixed(2), azDeg: +sun.azDeg.toFixed(1) }, bbox: bbox.map(v => +v.toFixed(5)), buildingCount: buildings.length, treeCount: trees.length, leafFrac, routes: routes.map((rt, idx) => ({ index: idx, distanceM: Math.round(rt.distance), sunScore: +rt.sunScore.toFixed(4), shadedSegments: rt.segShade.filter(s => s.shade).length, totalSegments: rt.segShade.length })) }));
  }

  async function handleSearch() {
    const startQ = input('inp-start').value.trim();
    const endQ   = input('inp-end').value.trim();
    const dateV  = input('inp-date').value;
    const timeV  = input('inp-time').value;

    if (!startQ || !endQ) { showToast(tr('alert_empty')); return; }

    const btn = button('search-btn');
    btn.disabled = true;
    el('results').classList.remove('on');
    el('compass-wrap').classList.remove('on');

    try {
      setStatus(tr('status_geocoding'));
      const [startC, endC] = await Promise.all([
        startAC.getPlace() ?? geocode(startQ),
        endAC.getPlace()   ?? geocode(endQ),
      ]);

      const midLat = (startC.lat + endC.lat) / 2;
      const midLng = (startC.lng + endC.lng) / 2;

      // Date/time inputs are wall-clock values for the route's location, not
      // the browser's — resolve the destination's IANA zone and convert.
      const destTz = resolveTimeZone(midLat, midLng);
      let tDate = new Date();
      if (dateV) {
        tDate = zonedTimeToUtc(`${dateV}T${timeV || '12:00'}`, destTz);
      }

      const sun = getSun(tDate, midLat, midLng);
      // Night: sun exposure doesn't apply — no weather badge, no compass,
      // no shadow computation; just show the shortest route and say so.
      const night = sun.altDeg <= 0;

      // Fired now, awaited only before rendering results: the routing +
      // Overpass calls below dwarf it, so it's effectively free. Resolves
      // to null when the date is beyond the forecast horizon or on error.
      const weatherP = night ? Promise.resolve(null) : fetchWeather(midLat, midLng, tDate);

      updateSunInfo(sun, getSunTimes(tDate, midLat, midLng), destTz);
      drawCompass(sun.azDeg, sun.altDeg);
      el('compass-wrap').classList.toggle('on', !night);

      const routes = await buildRoutes(startC, endC, setStatus);
      if (!routes.length) throw new Error(tr('error_no_route'));

      const bbox = routesBbox(routes);
      let buildings: Awaited<ReturnType<typeof fetchBuildings>> = [];
      let trees: Awaited<ReturnType<typeof fetchVegetation>>['trees'] = [];
      let forests: Awaited<ReturnType<typeof fetchVegetation>>['forests'] = [];
      let leafFrac = 1;
      if (!night) {
        // At night every route scores 0 — shadow geometry is pointless,
        // so skip the two Overpass round trips entirely.
        setStatus(tr('status_buildings'));
        [buildings, { trees, forests }] = await Promise.all([
          fetchBuildings(bbox),
          fetchVegetation(bbox),
        ]);
        leafFrac = deciduousLeafFrac(tDate, midLat);
        setStatus(tr('status_shadows', { n: String(buildings.length), r: String(routes.length) }));
      }
      // The sun moves ~11° azimuth over a 45-min walk — enough to flip which
      // side of a street is shaded. Score each segment with the sun at its
      // estimated arrival time instead of freezing it at departure.
      const sunSampler = makeSunSampler(tDate, midLat, midLng);
      routes.forEach(rt => {
        const { score, segShade } = scoreRoute(rt, buildings, trees, sunSampler, leafFrac, forests);
        rt.sunScore = score;
        rt.segShade = segShade;
      });
      routes.sort((a, b) => b.sunScore - a.sunScore);

      let sunny = routes[0];
      const shady = routes[routes.length - 1];
      // Night collapses the sunny/shady distinction: show only the shortest route.
      if (night) sunny = routes.reduce((a, b) => (b.distance < a.distance ? b : a));
      const single = night || routes.length === 1;

      displayRoutes(startC, endC, sunny, single ? null : shady);
      showResults(sunny, shady, single, night);

      const weather = await weatherP;
      const weatherEl = el('weather-note');
      if (weather && weather.cloudCover >= OVERCAST_PCT) {
        weatherEl.textContent = tr('weather_overcast', { pct: String(Math.round(weather.cloudCover)) });
        weatherEl.classList.add('on');
      } else {
        weatherEl.classList.remove('on');
      }

      // Make the result shareable/bookmarkable: reflect the search in the URL.
      history.replaceState(null, '', location.pathname + '?' + buildShareQuery({
        start: { ...startC, label: startQ },
        end:   { ...endC,   label: endQ },
        date: dateV,
        time: timeV,
      }));

      const preselect = single ? 'sunny' : preselectTab({
        altDeg: sun.altDeg,
        temperature: weather?.temperature ?? null,
        month: tDate.getUTCMonth(),
        lat: midLat,
      });
      setActiveTab(preselect);
      setActiveRoute(preselect);
      setStatus(null);

      logShadowDebug({ startQ, endQ, startC, endC, tDate, sun, bbox, buildings, trees, leafFrac, routes });

    } catch (err) {
      setStatus(null);
      if ((err as { code?: string })?.code === 'RATE_LIMIT') {
        showToast(tr('error_rate_limit'));
      } else {
        showToast(tr('error_prefix') + (err instanceof Error ? err.message : String(err)));
      }
      console.error(err);
    } finally {
      button('search-btn').disabled = false;
    }
  }

  async function fillFromGeo(ac: ReturnType<typeof initAutocomplete>, role: 'start' | 'end', btnId: string) {
    const btn = button(btnId);
    btn.disabled = true;
    btn.classList.add('loading');
    setStatus(tr('geo_loading'));
    try {
      const pos = await new Promise<GeolocationPosition>((resolve, reject) => {
        navigator.geolocation.getCurrentPosition(resolve, reject, { timeout: 10000 });
      });
      const label = await reverseGeocode(pos.coords.latitude, pos.coords.longitude);
      const lat = pos.coords.latitude, lng = pos.coords.longitude;
      ac.setPlace({ lat, lng, label });
      setPreviewPin(role, { lat, lng });
      setStatus(null);
    } catch (err: unknown) {
      setStatus(null);
      if ((err as GeolocationPositionError)?.code === 1) {
        showToast(tr('error_geo_denied'));
      } else {
        showToast(tr('error_geo_timeout'));
      }
    } finally {
      btn.disabled = false;
      btn.classList.remove('loading');
    }
  }

  button('geo-start').addEventListener('click', () => fillFromGeo(startAC, 'start', 'geo-start'));
  button('geo-end').addEventListener('click',   () => fillFromGeo(endAC,   'end',   'geo-end'));

  let swapAngle = 0;
  function swapEndpoints() {
    const a = startAC.getState();
    const b = endAC.getState();
    startAC.setState(b);
    endAC.setState(a);
    swapPreviewPins();
    // Accumulate the angle so the transition replays in full on every click.
    swapAngle += 180;
    el<HTMLElement>('swap-btn').querySelector<HTMLElement>('.swap-ico')!
      .style.transform = `rotate(${swapAngle}deg)`;
  }
  button('swap-btn').addEventListener('click', swapEndpoints);

  button('search-btn').addEventListener('click', handleSearch);
  ['inp-start', 'inp-end'].forEach(id =>
    input(id).addEventListener('keydown', (e: KeyboardEvent) => { if (e.key === 'Enter') handleSearch(); })
  );

  // Share the current URL (kept in sync by handleSearch). navigator.share opens
  // the native share sheet on mobile (WhatsApp, SMS, copy link…); elsewhere we
  // fall back to copying the link.
  button('share-btn').addEventListener('click', async () => {
    const url = location.href;
    if (navigator.share) {
      try { await navigator.share({ title: document.title, url }); }
      catch { /* user dismissed the share sheet */ }
    } else {
      await navigator.clipboard.writeText(url);
      showToast(tr('toast_link_copied'), 'success');
    }
  });

  // Shared/bookmarked link: restore start/end/datetime from the URL and search.
  const shared = parseShareQuery(location.search);
  if (shared.date) input('inp-date').value = shared.date;
  if (shared.time) input('inp-time').value = shared.time;
  if (shared.start) { startAC.setPlace(shared.start); setPreviewPin('start', shared.start); }
  if (shared.end)   { endAC.setPlace(shared.end);     setPreviewPin('end',   shared.end); }
  if (shared.start && shared.end) handleSearch();

  const drawer  = el('about-drawer');
  const overlay = el('about-overlay');

  function openAbout() {
    drawer.classList.add('open');
    overlay.classList.add('on');
  }
  function closeAbout() {
    drawer.classList.remove('open');
    overlay.classList.remove('on');
  }

  el('about-btn').addEventListener('click', openAbout);
  el('about-close').addEventListener('click', closeAbout);
  overlay.addEventListener('click', closeAbout);
  document.addEventListener('keydown', (e: KeyboardEvent) => { if (e.key === 'Escape') closeAbout(); });

</script>

</body>
</html>
